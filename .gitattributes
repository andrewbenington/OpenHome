# Originally written by https://github.com/coolguygus as part of a larger PR

# Merge strategies for specific files
# This helps Git handle conflicts more intelligently

# always regenerate, never merge
package-lock.json merge=ours
yarn.lock merge=ours
Cargo.lock merge=ours

# Line ending normalization
* text=auto
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.rs text eol=lf

# Binary files
*.pk9 binary
*.pk8 binary
*.pk7 binary
*.pk6 binary
*.pk5 binary
*.pk4 binary
*.pa9 binary
*.ohpkm binary
*.sav binary
*.exe binary