{
  "productName": "OpenHome",
  "name": "openhome",
  "version": "1.14.2",
  "description": "A tool for moving Pokémon between game saves",
  "keywords": [
    "pokemon",
    "home",
    "openhome"
  ],
  "homepage": "https://github.com/andrewbenington/OpenHome#readme",
  "bugs": {
    "url": "https://github.com/andrewbenington/OpenHome/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewbenington/OpenHome.git"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=v24.2.0"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Andrew Benington",
    "email": "andrewbenington57@gmail.com"
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "scripts/*"
  ],
  "main": "./out/main/index.js",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "format": "prettier --write .",
    "lint": "pnpm run lint:ci --fix && cargo clippy -- -Dwarnings",
    "lint:ci": "eslint src --max-warnings 0 --report-unused-disable-directives -c eslint.config.mjs",
    "typecheck": "tsgo",
    "build": "pnpm run wasm-compile && pnpm vite build",
    "dev": "pnpm run wasm-compile-dev && pnpm vite",
    "tauri": "tauri",
    "test-cargo": "cargo test --workspace --all-features --tests -- --skip export_typescript_bindings",
    "test-vite": "pnpm run wasm-compile-dev && vitest run",
    "test": "pnpm run test-cargo && pnpm run test-vite",
    "wasm-compile-dev": "wasm-pack build ./pkm_rs --target web -- --features wasm && node scripts/patch-types.mjs",
    "wasm-compile": "wasm-pack build --release ./pkm_rs --target web -- --features wasm && node scripts/patch-types.mjs",
    "precommit": "pnpm run typecheck && pnpm run format && pnpm run lint",
    "postinstall": "pnpm run wasm-compile-dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/collision": "^0.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/react": "^0.5.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/themes": "^3.3.0",
    "@tanstack/react-virtual": "^3.14.6",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "chart.js": "^4.5.1",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.21",
    "immer": "^11.1.15",
    "prando": "^6.0.1",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-data-grid": "7.0.0-beta.61",
    "react-error-boundary": "^6.1.2",
    "react-icons": "^5.7.0",
    "react-router": "^8.2.0",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "better-sqlite3": "^12.11.1",
    "camelcase-keys": "^10.0.2",
    "chalk": "^5.6.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "execa": "^9.6.1",
    "globby": "^16.2.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
