{
  "compilerOptions": {
    "strict": true,
    "composite": true,
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "paths": {
      "@openhome-ui/*": [
        "./src/ui/*"
      ],
      "@openhome-core/*": [
        "./src/core/*"
      ],
      "@openhome-core/resources/*": [
        "./src/core/resources/*"
      ],
      "@pkm-rs/*": [
        "./pkm_rs/*"
      ],
      "@pkm-rs": [
        "./pkm_rs"
      ]
    },
    "typeRoots": ["./src/types", "./node_modules/@types"],
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    /* Linting */
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "packages",
    "generate/_rename.js",
    "generate/generateMoveMap.ts",
    "src-tauri/pokemon-wasm",
    "generate/generate-cfru/generateMoveMap.ts",
    "src/types/pkm-resources-types.d.ts",
    "__mocks__"
  ]
}